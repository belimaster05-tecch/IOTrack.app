# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API

# URL del proyecto (público)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Clave anónima (público)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key"

# Clave service_role (SECRETO — nunca expongas en el cliente)
# Usada en: API routes, scripts de prueba
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# ─── App ──────────────────────────────────────────────────────────────────────
# URL base de la app (sin slash final)
# Desarrollo: http://localhost:3000
# Producción: https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
